---
interface Props {
  /** Uppercase label shown above the subsection content. */
  title?: string;
  /** Supporting context shown below the subsection content. */
  description?: string;
  class?: string;
}

const { title, description, class: className } = Astro.props;
---

<div class:list={["subsection", className]} data-node-id="71:821">
  <p class="title" data-node-id="71:812">{title}</p>

  <ul class="content" data-node-id="71:822">
    <slot />
  </ul>

  <p class="description" data-node-id="71:818">
    {description}
  </p>
</div>

<style>
  ul {
    list-style-type: none;
    margin: 0;
    padding: 0;
  }
  .subsection {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--spacing-m, 1rem);
    width: 100%;
  }

  .title,
  .description {
    width: 100%;
    margin: 0;
    overflow-wrap: anywhere;
    color: var(--text-muted);
  }

  .title {
    font-family: var(--ff-heading, "Proxima Nova", sans-serif);
    font-size: var(--font-size-md, 1rem);
    color: var(--text-muted);
    font-weight: 600;
    line-height: normal;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .content {
    width: 100%;
    min-height: 5.0625rem;
  }

  .description {
    font-family: var(--ff-body, "Proxima Nova", sans-serif);
    font-size: var(--font-size-sm, 0.813rem);
    font-weight: 400;
    line-height: 1.4;
  }
</style>
