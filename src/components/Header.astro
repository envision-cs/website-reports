---
import Logo from "../assets/logo.svg";
---

<header class="header">
  <div class="container navigation">
    <a href="/">
      <Logo class="logo" />
    </a>
    <a class="taskboard" href="/taskboard/">
      <span>Task Board</span>
      <svg
        class="taskboard__arrow"
        viewBox="0 0 24 24"
        width="24"
        height="24"
        aria-hidden="true"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="square"
        stroke-linejoin="miter"
      >
        <path d="M4 12h15M13 6l6 6-6 6" />
      </svg>
    </a>
  </div>
</header>

<style>
  .header {
    padding: var(--spacing-s);
  }
  .logo {
  }

  .navigation {
    display: flex;
    align-items: center;
  }

  .taskboard {
    margin-inline-start: auto;
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);

    color: var(--text-main);
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 600;
    font-size: var(--font-size-md);
    letter-spacing: 0.2em;

    transition: opacity 150ms ease;
  }

  .taskboard:hover,
  .taskboard:focus-visible {
    opacity: 0.7;
  }

  .taskboard__arrow {
    flex-shrink: 0;
    transition: transform 150ms ease;
  }

  .taskboard:hover .taskboard__arrow,
  .taskboard:focus-visible .taskboard__arrow {
    transform: translateX(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .taskboard,
    .taskboard__arrow {
      transition: none;
    }
  }
</style>
