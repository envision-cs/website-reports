---
import Layout from "../layouts/Layout.astro";
import { env } from 'cloudflare:workers';

const syncSecret = (env as any)?.SYNC_SECRET || "";
---

<Layout pageTitle="Home">
  <div class="wrap intro">
    <div class="eyebrow">Work Tracker</div>
    <h1 class="h1">What's in flight.</h1>
  </div>

  <div class="board" id="board" data-sync-secret={syncSecret} aria-label="Kanban board">
    <section class="column" data-status="todo">
      <header class="column__header">
        <h2 class="column__title">To do</h2>
        <span
          class="column__count"
          aria-label="cards in column"
          aria-live="polite">0</span
        >
      </header>
      <div class="column__cards" role="list"></div>
      <form class="column__add">
        <textarea
          name="title"
          rows="1"
          placeholder="Add a card…"
          required=""
          aria-label="Add a card to To do"></textarea>
        <button type="submit" aria-label="Add card">+</button>
        <textarea
          name="description"
          rows="1"
          placeholder="Description — optional"
          aria-label="Description for the new card in To do"></textarea>
      </form>
    </section><section class="column" data-status="doing">
      <header class="column__header">
        <h2 class="column__title">In progress</h2>
        <span
          class="column__count"
          aria-label="cards in column"
          aria-live="polite">0</span
        >
      </header>
      <div class="column__cards" role="list"></div>
      <form class="column__add">
        <textarea
          name="title"
          rows="1"
          placeholder="Add a card…"
          required=""
          aria-label="Add a card to In progress"></textarea>
        <button type="submit" aria-label="Add card">+</button>
        <textarea
          name="description"
          rows="1"
          placeholder="Description — optional"
          aria-label="Description for the new card in In progress"></textarea>
      </form>
    </section><section class="column" data-status="done">
      <header class="column__header">
        <h2 class="column__title">Done</h2>
        <span
          class="column__count"
          aria-label="cards in column"
          aria-live="polite">0</span
        >
      </header>
      <div class="column__cards" role="list"></div>
      <form class="column__add">
        <textarea
          name="title"
          rows="1"
          placeholder="Add a card…"
          required=""
          aria-label="Add a card to Done"></textarea>
        <button type="submit" aria-label="Add card">+</button>
        <textarea
          name="description"
          rows="1"
          placeholder="Description — optional"
          aria-label="Description for the new card in Done"></textarea>
      </form>
    </section>
  </div>
  <p
    id="board-live"
    class="visually-hidden"
    aria-live="polite"
    aria-atomic="true"
  >
  </p>
  <template id="column-template">
      <div class="column">
      <header class="column__header">
        <h2 class="column__title"></h2>
        <span
          class="column__count"
          aria-label="cards in column"
          aria-live="polite"></span>
      </header>
      <div class="column__cards" role="list"></div>
      <form class="column__add">
        <textarea name="title" rows="1" placeholder="Add a card…" required=""
        ></textarea>
        <button type="submit" aria-label="Add card">+</button>
        <textarea
          name="description"
          rows="1"
          placeholder="Description — optional"></textarea>
      </form>
      </div>
  </template>
  <template id="card-template">
    <article class="card" role="listitem" draggable="true" tabindex="0">
      <div class="card__body">
        <span class="card__title"></span>
        <p class="card__desc"></p>
      </div>
      <button
        class="card__delete"
        commandfor=""
        command="toggle-popover"
        aria-label="Delete card">×</button
      >
      <div class="card__confirm" popover="" role="alertdialog">
        <p>Delete this card?</p>
        <button data-confirm="" commandfor="" command="hide-popover"
          >Delete</button
        >
        <button commandfor="" command="hide-popover">Keep</button>
      </div>
    </article>
  </template>
</Layout>

<script>
  import { store } from "../lib/taskboard/storage.ts";

  const COLUMNS = [
    {
      id: "todo",
      label: "To do",
    },
    {
      id: "doing",
      label: "In progress",
    },
    {
      id: "done",
      label: "Done",
    },
  ];

  /* ---------- storage: localStorage instead of a server ---------- */
  const KEY = "kanban.cards.v1";

  const boardStore = store(KEY);

  // Sync across open tabs: another tab writes, this one re-renders.
  addEventListener("storage", (e) => {
    if (e.key !== KEY) return;
    boardStore.cards = new Map(
      JSON.parse(e.newValue ?? "[]").map((c: any) => [c.id, c]),
    );
    transition(() => render());
  });

  // Client Sync Layer
  let syncTimeout: any = null;
  let maxWaitTimeout: any = null;
  let isDirty = false;
  const DEBOUNCE_MS = 3000;
  const MAX_WAIT_MS = 120000;

  function getLocalUpdatedAt(): number {
    const val = localStorage.getItem(KEY + ".updatedAt");
    return val ? Number(val) : 0;
  }

  function markDirty() {
    isDirty = true;
    localStorage.setItem(KEY + ".updatedAt", Date.now().toString());
    scheduleSync();
  }

  function scheduleSync() {
    if (syncTimeout) clearTimeout(syncTimeout);

    if (!maxWaitTimeout) {
      maxWaitTimeout = setTimeout(() => {
        flushSync();
      }, MAX_WAIT_MS);
    }

    syncTimeout = setTimeout(() => {
      flushSync();
    }, DEBOUNCE_MS);
  }

  /* ---------- rendering ---------- */
  const board = document.getElementById("board");
  const syncSecret = board?.dataset.syncSecret || "";

  async function flushSync() {
    if (syncTimeout) {
      clearTimeout(syncTimeout);
      syncTimeout = null;
    }
    if (maxWaitTimeout) {
      clearTimeout(maxWaitTimeout);
      maxWaitTimeout = null;
    }
    if (!isDirty) return;
    const cards = boardStore.list();
    const updatedAt = getLocalUpdatedAt();

    const headers: Record<string, string> = {
      "Content-Type": "application/json",
    };
    if (syncSecret) {
      headers["Authorization"] = `Bearer ${syncSecret}`;
    }

    try {
      const response = await fetch("/api/board", {
        method: "PUT",
        headers,
        body: JSON.stringify({ cards, updatedAt }),
      });
      if (response.ok) {
        isDirty = false;
        console.log("Successfully synced taskboard to Cloudflare KV.");
      } else {
        console.log(response)
        console.error("Failed to sync taskboard to KV:", response.statusText);
        scheduleSync();
      }
    } catch (err) {
      console.error("Error syncing taskboard to KV:", err);
      scheduleSync();
    }
  }

  function flushSyncBeacon() {
    if (!isDirty) return;
    const cards = boardStore.list();
    const updatedAt = getLocalUpdatedAt();

    const headers: Record<string, string> = {
      "Content-Type": "application/json",
    };
    if (syncSecret) {
      headers["Authorization"] = `Bearer ${syncSecret}`;
    }

    fetch("/api/board", {
      method: "PUT",
      headers,
      body: JSON.stringify({ cards, updatedAt }),
      keepalive: true,
    }).catch(err => console.error("Exit sync failed:", err));
  }

  addEventListener("visibilitychange", () => {
    if (document.visibilityState === "hidden") {
      flushSyncBeacon();
    }
  });

  addEventListener("pagehide", () => {
    flushSyncBeacon();
  });

  async function hydrateFromKV() {
    try {
      const headers: Record<string, string> = {};
      if (syncSecret) {
        headers["Authorization"] = `Bearer ${syncSecret}`;
      }

      const response = await fetch("/api/board", { headers });
      if (!response.ok) {
        console.error("Failed to fetch taskboard from KV:", response.statusText);
        return;
      }

      const remoteData = await response.json();
      if (!remoteData || !Array.isArray(remoteData.cards)) return;

      const localUpdatedAt = getLocalUpdatedAt();
      const remoteUpdatedAt = remoteData.updatedAt || 0;

      if (remoteUpdatedAt > localUpdatedAt) {
        console.log("Remote board is newer. Hydrating local state...");
        localStorage.setItem(KEY, JSON.stringify(remoteData.cards));
        localStorage.setItem(KEY + ".updatedAt", remoteUpdatedAt.toString());

        boardStore.cards = new Map(remoteData.cards.map((c: any) => [c.id, c]));
        transition(() => render());
      } else if (remoteUpdatedAt < localUpdatedAt && localUpdatedAt > 0) {
        console.log("Local board is newer. Triggering sync to KV...");
        isDirty = true;
        flushSync();
      }
    } catch (err) {
      console.error("Error during KV hydration:", err);
    }
  }

  hydrateFromKV();

  const liveRegion = document.getElementById("board-live");
  const columnTpl = document.querySelector("#column-template");
  const cardTpl = document.getElementById("card-template");
  const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)");
  const transition = (fn) =>
    !reduceMotion.matches && document.startViewTransition
      ? document.startViewTransition(fn).finished
      : (fn(), Promise.resolve());
  let activeDrag = null;
  let selectedCardId = null;

  function makeCard(card) {
    const el = cardTpl.content.firstElementChild.cloneNode(true);
    el.dataset.id = card.id;
    el.dataset.position = card.position;
    el.style.viewTransitionName = `card-${card.id}`;
    el.style.anchorName = `--card-${card.id}`;
    const pop = el.querySelector(".card__confirm");
    pop.id = `confirm-${card.id}`;
    pop.style.positionAnchor = `--card-${card.id}`;
    for (const b of el.querySelectorAll("[commandfor]"))
      b.setAttribute("commandfor", pop.id);
    pop
      .querySelector("[data-confirm]")
      .addEventListener("click", () => deleteCard(el));
    pop.addEventListener("toggle", (e) => {
      if (e.newState === "open") {
        pop.querySelector("[data-confirm]").focus();
      }
    });
    pop.querySelector("p").textContent = `Delete “${card.title}”?`;
    const title = el.querySelector(".card__title");
    title.textContent = card.title;
    const desc = el.querySelector(".card__desc");
    desc.textContent = card.description ?? "";
    el.dataset.selected = String(card.id === selectedCardId);
    el.addEventListener("click", (e) => {
      if (e.target.closest("button, [popover]")) return;
      if (title.isContentEditable || desc.isContentEditable) return;
      selectCard(el);
    });
    el.addEventListener("dragstart", (e) => {
      activeDrag = {
        element: el,
        originalList: el.parentElement,
        originalNextSibling: el.nextElementSibling,
        committed: false,
      };
      e.dataTransfer.setData("text/plain", card.id);
      e.dataTransfer.effectAllowed = "move";
      requestAnimationFrame(() => {
        el.classList.add("card--dragging");
      });
    });
    el.addEventListener("dragend", () => {
      if (activeDrag?.element === el && !activeDrag.committed) {
        const nextSibling = activeDrag.originalNextSibling?.isConnected
          ? activeDrag.originalNextSibling
          : null;
        activeDrag.originalList.insertBefore(el, nextSibling);
      }
      board
        .querySelectorAll(".column--over")
        .forEach((column) => column.classList.remove("column--over"));
      board.querySelectorAll(".column").forEach(updateCount);
      el.classList.remove("card--dragging");
      activeDrag = null;
    });
    el.addEventListener("dblclick", (e) => {
      if (e.target.closest(".card__desc")) startEdit(el, desc, "description");
      else startEdit(el, title);
    });
    el.addEventListener("keydown", (e) => {
      if (e.target !== el || title.isContentEditable || desc.isContentEditable)
        return;
      const shortcut = e.altKey ? `Alt+${e.key}` : e.key;
      switch (shortcut) {
        case "Alt+ArrowUp":
          e.preventDefault();
          moveVertically(el, -1);
          break;
        case "Alt+ArrowDown":
          e.preventDefault();
          moveVertically(el, 1);
          break;
        case " ":
          e.preventDefault();
          selectCard(el);
          break;
        case "Enter":
          e.preventDefault();
          if (e.shiftKey) startEdit(el, desc, "description");
          else startEdit(el, title);
          break;
        case "Delete":
          e.preventDefault();
          pop.showPopover();
          break;
        case "ArrowLeft":
          e.preventDefault();
          moveByKeyboard(el, -1);
          break;
        case "ArrowRight":
          e.preventDefault();
          moveByKeyboard(el, 1);
          break;
      }
    });
    return el;
  }

  function editSession(title) {
    const controller = new AbortController();
    return {
      signal: controller.signal,
      [Symbol.dispose]() {
        controller.abort();
        title.removeAttribute("contenteditable");
      },
    };
  }
  async function startEdit(el, field, key = "title") {
    const before = field.textContent;
    const { promise, resolve } = Promise.withResolvers();
    using session = editSession(field);
    field.contentEditable = "plaintext-only";
    field.focus();
    getSelection().selectAllChildren(field);
    field.addEventListener("dblclick", () => startEdit(el, field, key));
    field.addEventListener("blur", () => resolve(true), {
      signal: session.signal,
    });
    field.addEventListener(
      "keydown",
      (e) => {
        if (e.key === "Enter" && !e.shiftKey)
          (e.preventDefault(), resolve(true));
        if (e.key === "Escape") resolve(false);
      },
      {
        signal: session.signal,
      },
    );
    const save = await promise;
    const next = field.textContent.trim();
    const required = key === "title";
    if (!save || next === before || (required && !next)) {
      field.textContent = before;
      return;
    }
    field.textContent = next;
    boardStore.update(el.dataset.id, {
      [key]: next,
    });
    markDirty()
  }
  async function deleteCard(el) {
    const column = el.closest(".column");
    boardStore.remove(el.dataset.id);
    markDirty()
    await transition(() => {
      el.remove();
      updateCount(column);
    });
  }
  async function moveByKeyboard(el, dir) {
    const cols = [...board.querySelectorAll(".column")];
    const target = cols[cols.indexOf(el.closest(".column")) + dir];
    if (!target) return;
    const list = target.querySelector(".column__cards");
    const last = [...list.querySelectorAll(".card")].at(-1);
    const position = last ? Number(last.dataset.position) + 1 : 1;
    await transition(() => {
      list.moveBefore(el, null);
      cols.forEach(updateCount);
    });
    el.dataset.position = position;
    el.focus();
    store.update(el.dataset.id, {
      status: target.dataset.status,
      position,
    });
  }
  async function moveVertically(el, direction) {
    const column = el.closest(".column");
    const list = column.querySelector(".column__cards");
    const cards = [...list.querySelectorAll(".card")];
    const currentIndex = cards.indexOf(el);
    const targetIndex = currentIndex + direction;
    if (targetIndex < 0 || targetIndex >= cards.length) {
      announce(
        direction < 0
          ? "Card is already first in the column."
          : "Card is already last in the column.",
      );
      return;
    }
    const targetCard = cards[targetIndex];
    await transition(() => {
      if (direction < 0) {
        list.moveBefore(el, targetCard);
      } else {
        list.moveBefore(el, targetCard.nextElementSibling);
      }
    });
    persistBoardOrder();
    el.focus();
    const reorderedCards = [...list.querySelectorAll(".card")];
    const newPosition = reorderedCards.indexOf(el) + 1;
    const columnName = column
      .querySelector(".column__title")
      .textContent.trim();
    const cardName = el.querySelector(".card__title").textContent.trim();
    announce(
      `Moved ${cardName} to position ${newPosition} of ${reorderedCards.length} in ${columnName}.`,
    );
  }

  function updateCount(column) {
    column.querySelector(".column__count").textContent =
      column.querySelectorAll(".card").length;
  }

  function selectCard(el) {
    const wasSelected = el.dataset.selected === "true";
    board.querySelectorAll('.card[data-selected="true"]').forEach((card) => {
      card.dataset.selected = "false";
    });
    if (wasSelected) {
      selectedCardId = null;
      announce(`${el.querySelector(".card__title").textContent} deselected.`);
      return;
    }
    el.dataset.selected = "true";
    selectedCardId = el.dataset.id;
    announce(`${el.querySelector(".card__title").textContent} selected.`);
  }

  function announce(message) {
    liveRegion.textContent = "";
    requestAnimationFrame(() => {
      liveRegion.textContent = message;
    });
  }

  function persistBoardOrder() {
    for (const column of board.querySelectorAll(".column")) {
      const status = column.dataset.status;
      const cards = [...column.querySelectorAll(".card")];
      cards.forEach((element, index) => {
        const position = index + 1;
        const card = boardStore.cards.get(element.dataset.id);
        if (!card) return;
        card.status = status;
        card.position = position;
        element.dataset.position = position;
      });
    }
    boardStore.persist();
    markDirty()
  }
  /* ---------- drag and drop ---------- */
  function getCardAfter(list, y) {
    const cards = [...list.querySelectorAll(".card:not(.card--dragging)")];
    return (
      cards.find((c) => {
        const box = c.getBoundingClientRect();
        return y < box.top + box.height / 2;
      }) ?? null
    );
  }

  function wireColumn(column, status) {
    const list = column.querySelector(".column__cards");
    list.addEventListener("dragover", (e) => {
      e.preventDefault();
      const dragging = document.querySelector(".card--dragging");
      if (!dragging) return;
      column.classList.add("column--over");
      const after = getCardAfter(list, e.clientY);
      if (
        dragging.parentElement !== list ||
        dragging.nextElementSibling !== after
      ) {
        list.moveBefore(dragging, after);
      }
    });
    list.addEventListener("dragleave", (e) => {
      if (!column.contains(e.relatedTarget))
        column.classList.remove("column--over");
    });
    list.addEventListener("drop", (e) => {
      e.preventDefault();
      const dragging = document.querySelector(".card--dragging");
      if (!dragging) return;
      if (activeDrag?.element === dragging) {
        activeDrag.committed = true;
        persistBoardOrder();
      }
      board
        .querySelectorAll(".column--over")
        .forEach((column) => column.classList.remove("column--over"));
      board.querySelectorAll(".column").forEach(updateCount);
      persistBoardOrder();
    });
    const form = column.querySelector(".column__add");
    const input = form.elements.title;
    const descInput = form.elements.description;
    for (const field of [input, descInput]) {
      field.addEventListener("keydown", (e) => {
        if (e.key === "Enter" && !e.shiftKey)
          (e.preventDefault(), form.requestSubmit());
      });
    }
    input.setAttribute(
      "aria-label",
      `Add a card to ${column.querySelector(".column__title").textContent}`,
    );
    descInput.setAttribute(
      "aria-label",
      `Description for the new card in ${column.querySelector(".column__title").textContent}`,
    );
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const title = input.value.trim();
      if (!title) return;
      const description = descInput.value.trim();
      input.value = "";
      descInput.value = "";
      const card = boardStore.create(title, description, status);
      markDirty()
      await transition(() => {
        list.appendChild(makeCard(card));
        updateCount(column);
      });
    });
  }
  /* ---------- init ---------- */
  function render() {
    board.replaceChildren();
    const byStatus = Map.groupBy(boardStore.list(), (c) => c.status);
    for (const { id, label } of COLUMNS) {
      const column = columnTpl.content.firstElementChild.cloneNode(true);
      column.dataset.status = id;
      column.querySelector(".column__title").textContent = label;
      const list = column.querySelector(".column__cards");
      (byStatus.get(id) ?? [])
        .toSorted((a, b) => a.position - b.position)
        .forEach((c) => list.appendChild(makeCard(c)));
      wireColumn(column, id);
      board.appendChild(column);
      updateCount(column);
    }
  }

  render();
  hydrateFromKV();
</script>

<style>
  @layer tokens, base, components, motion;

  @layer tokens {
    :root {
      color-scheme: dark;
      --bg: #141414;
      --surface: #212121;
      --surface-2: #181818;
      --ink: #ffffff;
      --ink-soft: #9a9a9a;
      --ink-faint: #6f6f6f;
      --line: #262626;
      --line-2: #2e2e2e;
      --red: #e05c4a;
      --radius: 3px;
      --accent: #3baee8;
      --accent-soft: rgba(59, 174, 232, 0.07);
    }

    .column[data-status="todo"] {
      --accent: #8a8a8a;
      --accent-soft: rgba(160, 160, 160, 0.07);
    }

    .column[data-status="doing"] {
      --accent: #e8a23b;
      --accent-soft: rgba(232, 162, 59, 0.07);
    }

    .column[data-status="done"] {
      --accent: #4cb050;
      --accent-soft: rgba(76, 176, 80, 0.07);
    }
  }

  @layer base {
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100dvh;
      background: var(--bg);
      color: var(--ink);
      font-family: var(--ff-body);
      -webkit-font-smoothing: antialiased;
      container: page / inline-size;
      display: flex;
      flex-direction: column;
    }

    .visually-hidden {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      white-space: nowrap;
      clip-path: inset(50%);
      border: 0;
    }

    :focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }
  }

  @layer components {
    /* ---------- page chrome ---------- */
    .wrap {
      width: 100%;
      max-width: 1160px;
      margin-inline: auto;
      padding-inline: 48px;
    }

    .hdr {
      border-bottom: 1px solid var(--line);
    }

    .hdr__inner {
      height: 76px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .logo {
      font-size: 19px;
      font-weight: 800;
      letter-spacing: 0.3em;
    }

    .logo--sm {
      font-size: 15px;
    }

    .logo-o {
      color: #3baee8;
    }

    .hdrtag {
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink-soft);
    }

    .hdrnav {
      display: flex;
      align-items: center;
      gap: 28px;
    }

    .navlink {
      text-decoration: none;
      transition: color 0.15s;

      &:hover {
        color: #3baee8;
      }
    }

    .intro {
      padding-top: 72px;
    }

    .eyebrow {
      color: #3baee8;
      font-weight: 800;
      letter-spacing: 0.16em;
      font-size: 13px;
      text-transform: uppercase;
    }

    .h1 {
      font-size: 44px;
      font-weight: 600;
      line-height: 1.15;
      margin: 16px 0 0;
      letter-spacing: -0.01em;
    }

    .foot {
      border-top: 1px solid var(--line);
      margin-top: auto;
    }

    .foot__inner {
      height: 84px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .footnote {
      font-size: 12.5px;
      color: #777;
      letter-spacing: 0.04em;
    }

    /* ---------- board ---------- */
    .board {
      display: grid;
      grid-template-columns: repeat(3, minmax(240px, 1fr));
      gap: 20px;
      width: 100%;
      max-width: 1160px;
      margin-inline: auto;
      padding: 44px 48px 110px;
      align-items: start;

      &:has(.card--dragging) .card__delete {
        visibility: hidden;
      }
    }

    @container page (inline-size < 720px) {
      .board {
        grid-template-columns: 1fr;
