---
import MonthGrid from "../components/MonthGrid.astro";
import Layout from "../layouts/Layout.astro";
import PageHead from "../components/PageHead.astro";
---

<Layout pageTitle="Home">
  <section class="container">
    <PageHead
      eyebrow="Performance Reports"
      heading="Every month, on the record."
      body="A running archive of Envision's monthly SEO performance. Pick a year, then open any month to see that report."
    />
    <section>
      <MonthGrid />
    </section>
  </section>
</Layout>
