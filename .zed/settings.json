{
  "lsp": {
    "oxlint": {
      "initialization_options": {
        "settings": {
          "configPath": "./.oxlintrc.json",
          "disableNestedConfig": false,
          "fixKind": "safe_fix",
          "run": "onType",
          "unusedDisableDirectives": "deny"
        }
      }
    }
  },
  "languages": {
    "Astro": {
      "format_on_save": "on",
      "formatter": "language_server",
      "code_actions_on_format": {
        "source.fixAll.oxc": true
      }
    },
    "JavaScript": {
      "format_on_save": "on",
      "formatter": "language_server",
      "code_actions_on_format": {
        "source.fixAll.oxc": true
      }
    },
    "JSX": {
      "format_on_save": "on",
      "formatter": "language_server",
      "code_actions_on_format": {
        "source.fixAll.oxc": true
      }
    },
    "TypeScript": {
      "format_on_save": "on",
      "formatter": "language_server",
      "code_actions_on_format": {
        "source.fixAll.oxc": true
      }
    },
    "TSX": {
      "format_on_save": "on",
      "formatter": "language_server",
      "code_actions_on_format": {
        "source.fixAll.oxc": true
      }
    }
  }
}
